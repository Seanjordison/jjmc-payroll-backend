# ============================================================
#  JJMC Payroll Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env file to GitHub.
# ============================================================

# ----------------------------
# Server
# ----------------------------
PORT=5000
NODE_ENV=development

# ----------------------------
# Firebase Admin SDK
# Choose ONE option:
# Option A (recommended): path to your downloaded service account JSON
# Option B: inline base64 of the JSON (useful for hosting platforms)
# ----------------------------

# Option A – local file path (relative to project root)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B – base64 encoded service account JSON
# Generate with: base64 -i serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# ----------------------------
# Firebase Project
# ----------------------------
FIREBASE_PROJECT_ID=database-test-34eff

# ----------------------------
# CORS — comma-separated list of allowed origins
# ----------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8100

# ----------------------------
# Cloudinary (optional — used by deleteCloudinaryMedia)
# ----------------------------
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
